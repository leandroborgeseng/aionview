APP_NAME="AionView"

# PostgreSQL
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me"
AUTH_SECRET="change-me"

# PBI integration
PBI_BASE_URL="https://sjh.globalthings.net"
PBI_API_KEY="change-me"

# PBI API keys por endpoint (prioridade sobre PBI_API_KEY)
API_PBI_REL_CRONO_MANU="change-me"
API_PBI_TIP_MANU="change-me"
API_PBI_REL_OS_ANALITICO="change-me"
API_PBI_REL_EQUIPAMENTOS="change-me"
API_PBI_REL_TMEF="change-me"
API_PBI_REL_TPM="change-me"
API_PBI_REL_DISP_EQUIPAMENTO="change-me"
API_PBI_REL_DISP_EQUIPAMENTO_MES="change-me"
API_PBI_MONITOR_REACAO="change-me"
API_PBI_MONITOR_ATENDIMENTO="change-me"
API_PBI_ANEXOS_EQUIPAMENTO="change-me"
API_PBI_ANEXOS_OS="change-me"
API_PBI_REL_OS_ANALITICO_RESUMIDO="change-me"
API_PBI_OFICINA="change-me"

# Overrides de path dos endpoints (opcional, útil quando a API usa rotas diferentes)
PBI_PATH_CRONOGRAMA="/api/pbi/v1/cronograma"
PBI_PATH_TIPO_MANUTENCAO="/api/pbi/v1/tipo_manutencao"
PBI_PATH_OS_ANALITICO="/api/pbi/v1/listagem_analitica_das_os"
PBI_PATH_OS_ANALITICO_RESUMIDO="/api/pbi/v1/listagem_analitica_das_os_resumida"
PBI_PATH_EQUIPAMENTOS="/api/pbi/v1/equipamentos"
PBI_PATH_TMEF="/api/pbi/v1/tempo_medio_entre_falhas"
PBI_PATH_TPM="/api/pbi/v1/tempo_de_parada_medio"
PBI_PATH_DISPONIBILIDADE_EQUIPAMENTO="/api/pbi/v1/disponibilidade_equipamento"
PBI_PATH_MONITOR_REACAO="/api/pbi/v1/monitor_reacao"
PBI_PATH_MONITOR_ATENDIMENTO="/api/pbi/v1/monitor_atendimento"
PBI_PATH_OFICINA="/api/pbi/v1/oficina"
PBI_PATH_DISPONIBILIDADE_EQUIPAMENTO_MES_A_MES="/api/pbi/v1/disponibilidade_equipamento_mes_a_mes"
PBI_PATH_ANEXOS_EQUIPAMENTO="/api/pbi/v1/anexos_equipamento"
PBI_PATH_ANEXOS_OS="/api/pbi/v1/anexos_os"

# Parâmetros opcionais para disponibilidade mês a mês
PBI_DISP_MES_PERIODO=""
PBI_DISP_MES_DATA_INICIO=""
PBI_DISP_MES_DATA_FIM=""

# Parâmetros padrão para endpoints que exigem filtro obrigatório
PBI_DEFAULT_PERIODO="MesAtual"
PBI_DEFAULT_TIPO_MANUTENCAO="Todos"
PBI_DEFAULT_DATA_INICIO=""
PBI_DEFAULT_DATA_FIM=""
PBI_EMPRESAS_IDS=""
PBI_COMPANY_ID=""

# Cron / scheduler (invoca a rota interna de sync)
CRON_SECRET="change-me"

# Email (Resend)
RESEND_API_KEY="change-me"
EMAIL_FROM="AionView <no-reply@seu-dominio.com>"
EMAIL_REPLY_TO="engenharia.clinica@seu-dominio.com"

# Seed (mínimo)
SEED_ADMIN_EMAIL="admin@empresa.com"
SEED_ADMIN_PASSWORD="admin123456"
SEED_COMPANY_NAME="Empresa Principal"
SEED_UNIT_NAME="Unidade Principal"
SEED_SECTOR_NAME="Setor Principal"
SEED_WORKSHOP_NAME="Oficina Principal"

